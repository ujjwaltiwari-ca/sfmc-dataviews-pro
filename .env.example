# Public (embedded in the client bundle — anon key only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Analytics 4 (production only; optional locally)
VITE_GA_MEASUREMENT_ID=

# Optional pre-launch gate (omit or leave blank for public launch; server-only — never use VITE_)
# When set, visitors must enter this password before accessing the interactive workspace.
# SEO reference pages at /views/ remain publicly crawlable.
STAGING_PASSWORD=
# Required in production when STAGING_PASSWORD is set (never reuse the gate password)
STAGING_COOKIE_SECRET=

# Server-only (Vercel / local API routes — never use VITE_ prefix for secrets)
OPENAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=  # Copilot usage quota + /api/saved-queries

# Secret for POST /api/apply-migration (npm run deploy:migrate:prod). Do not reuse the service role key.
MIGRATION_SECRET=

# Optional: Upstash Redis for global rate limits in production (recommended when STAGING_PASSWORD is set)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Direct Postgres URL for one-time migrations (npm run db:migrate). Find in Supabase → Project Settings → Database.
# SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Or set only the database password (script tries common Supabase pooler regions):
# SUPABASE_DB_PASSWORD=

# Optional server alias (API routes also fall back to VITE_SUPABASE_URL if unset)
SUPABASE_URL=
