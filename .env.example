# Public (embedded in the client bundle — anon key only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional pre-launch gate (omit or leave blank in production to disable)
VITE_STAGING_PASSWORD=

# Server-only (Vercel / local API routes — never use VITE_ prefix for secrets)
OPENAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional server aliases (not exposed to the client)
SUPABASE_URL=
SUPABASE_ANON_KEY=
