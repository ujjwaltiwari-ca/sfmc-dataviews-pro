# Public (embedded in the client bundle — anon key only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Analytics 4 (production only; optional locally)
VITE_GA_MEASUREMENT_ID=

# Optional pre-launch gate (omit or leave blank to disable; server-only — never use VITE_)
STAGING_PASSWORD=
# Optional separate secret for staging unlock cookies (defaults to STAGING_PASSWORD)
STAGING_COOKIE_SECRET=

# Server-only (Vercel / local API routes — never use VITE_ prefix for secrets)
OPENAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional server aliases (not exposed to the client)
SUPABASE_URL=
SUPABASE_ANON_KEY=
